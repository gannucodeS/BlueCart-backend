PORT=3000

# Primary URI (usually mongodb+srv:// from Atlas)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/DATABASE?retryWrites=true&w=majority

# If npm start fails with: querySrv ECONNREFUSED _mongodb._tcp...
# your DNS/network may block SRV lookups. In Atlas → Connect → Drivers,
# copy the "Standard connection string" (mongodb://host:27017,host:27017/...)
# and paste it here as MONGODB_URI instead (or set MONGODB_URI_ALT and use one).

# =============================================================================
# SESSION & SECURITY
# =============================================================================
SESSION_DAYS=7
ADMIN_SECRET=bluecart@admin2026

# =============================================================================
# RAZORPAY PAYMENT GATEWAY
# Get keys from: https://dashboard.razorpay.com/app/keys
# =============================================================================
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# =============================================================================
# GOOGLE OAUTH (Firebase)
# Get from Firebase Console → Project Settings → Service Accounts
# =============================================================================
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# Google Client ID (for frontend Google Sign-In)
# Format: XXXXXXXX-XXXXXXXX.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# =============================================================================
# WHATSAPP OTP (Free options)
# Option 1: Twilio WhatsApp (production)
# Option 2: Use free WhatsApp Business API sandbox
# =============================================================================
WHATSAPP_API_URL=https://api.twilio.com/2010-04-01/Accounts/YOUR_ACCOUNT_SID/Messages.json
WHATSAPP_API_TOKEN=your_twilio_auth_token
WHATSAPP_FROM=whatsapp:+14155238886

# =============================================================================
# BANK DETAILS (for Bank Transfer payment option)
# =============================================================================
BANK_ACCOUNT_NUMBER=XXXXXXXXXXXX
BANK_IFSC=XXXX0000000
BANK_NAME=Sample Bank
BANK_ACCOUNT_NAME=BlueCart E-Commerce
UPI_ID=bluecart@upi
